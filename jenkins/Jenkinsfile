pipeline {
    agent any

    environment {
        AWS_REGION   = 'ap-southeast-1'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_REPO   = 'maxweather'
        SERVICE_NAME = 'weather-service'
        K8S_NAMESPACE = 'maxweather'
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHA    = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.GIT_BRANCH = sh(returnStdout: true, script: 'git rev-parse --abbrev-ref HEAD').trim()
                    env.IMAGE_TAG  = "${env.GIT_BRANCH}-${env.GIT_SHA}-${env.BUILD_NUMBER}"
                    env.ECR_IMAGE_STAGING = "${ECR_REGISTRY}/${IMAGE_REPO}-staging/${SERVICE_NAME}"
                    env.ECR_IMAGE_PROD    = "${ECR_REGISTRY}/${IMAGE_REPO}-production/${SERVICE_NAME}"
                }
                echo "Branch: ${env.GIT_BRANCH} | SHA: ${env.GIT_SHA} | Tag: ${env.IMAGE_TAG}"
            }
        }

        stage('Test') {
            steps {
                dir('app') {
                    sh '''
                        python -m venv .venv
                        . .venv/bin/activate
                        pip install --quiet -r requirements.txt
                        pip install --quiet -r requirements-dev.txt
                        python -m pytest tests/unit/ -v --tb=short --junitxml=test-results.xml
                    '''
                }
            }
            post {
                always {
                    junit 'app/test-results.xml'
                }
            }
        }

        stage('Build & Push') {
            steps {
                script {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"

                    def image = docker.build(
                        "${env.ECR_IMAGE_STAGING}:${env.IMAGE_TAG}",
                        "--no-cache --file app/Dockerfile app/"
                    )
                    image.push(env.IMAGE_TAG)
                }
            }
        }

        stage('Deploy — Staging') {
            steps {
                script {
                    _kubectlApply('staging', env.ECR_IMAGE_STAGING, env.IMAGE_TAG)
                    _waitForRollout('staging')
                }
            }
        }

        stage('Smoke Test — Staging') {
            steps {
                script {
                    _smokeTest('api-staging.maxweather.internal')
                }
            }
            // Pipeline stops here if smoke test fails — production is never touched
        }

        stage('Approval — Production') {
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input message: "Staging passed. Deploy ${env.IMAGE_TAG} to production?",
                          ok: 'Deploy to Production',
                          submitter: 'ops-team'
                }
            }
        }

        stage('Promote Image') {
            // Re-tag the staging-tested image into the production ECR repo.
            // Same binary that passed staging — no rebuild.
            steps {
                script {
                    sh """
                        docker pull ${env.ECR_IMAGE_STAGING}:${env.IMAGE_TAG}
                        docker tag  ${env.ECR_IMAGE_STAGING}:${env.IMAGE_TAG} \
                                    ${env.ECR_IMAGE_PROD}:${env.IMAGE_TAG}
                        docker push ${env.ECR_IMAGE_PROD}:${env.IMAGE_TAG}
                    """
                }
            }
        }

        stage('Deploy — Production') {
            steps {
                script {
                    _kubectlApply('production', env.ECR_IMAGE_PROD, env.IMAGE_TAG)
                    _waitForRollout('production')
                }
            }
        }

        stage('Health Check — Production') {
            steps {
                script {
                    _smokeTest('api.maxweather.internal')
                }
            }
        }

    }

    post {
        success {
            echo "Deployed ${env.IMAGE_TAG} to production successfully."
        }
        failure {
            script {
                // Rollback whichever environment last failed
                ['staging', 'production'].each { env_name ->
                    sh """
                        aws eks update-kubeconfig \
                          --region ${AWS_REGION} \
                          --name maxweather-${env_name} 2>/dev/null || true
                        kubectl rollout undo deployment/${SERVICE_NAME} \
                          -n ${K8S_NAMESPACE} 2>/dev/null || true
                    """
                }
            }
            echo "Pipeline failed — rollback attempted."
        }
        always {
            cleanWs()
        }
    }

}

// ── Helpers ───────────────────────────────────────────────────────────────────

def _kubectlApply(String environment, String ecrImage, String imageTag) {
    sh """
        aws eks update-kubeconfig --region ${AWS_REGION} --name maxweather-${environment}
        cd k8s/overlays/${environment}
        kustomize edit set image \
            ${ecrImage}:latest=${ecrImage}:${imageTag}
        kubectl apply -k .
    """
}

def _waitForRollout(String environment) {
    sh """
        aws eks update-kubeconfig --region ${AWS_REGION} --name maxweather-${environment}
        kubectl rollout status deployment/${SERVICE_NAME} \
            -n ${K8S_NAMESPACE} \
            --timeout=300s
    """
}

def _smokeTest(String host) {
    sh """
        STATUS=\$(curl -sf -o /dev/null -w '%{http_code}' http://${host}/health)
        [ "\$STATUS" = "200" ] || (echo "Health check failed: HTTP \$STATUS" && exit 1)

        STATUS=\$(curl -sf -o /dev/null -w '%{http_code}' \
            -H "Authorization: Bearer \${SMOKE_TEST_API_KEY}" \
            "http://${host}/weather?city=Singapore&units=metric")
        [ "\$STATUS" = "200" ] || (echo "Weather endpoint failed: HTTP \$STATUS" && exit 1)

        echo "Smoke tests passed for ${host}"
    """
}
